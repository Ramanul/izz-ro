{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/deepseek-v4-flash-free",
  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "bash": {
      "*": "allow",
      "git push*": "deny",
      "git restore*": "deny",
      "git reset*": "deny",
      "git stash*": "deny",
      "git clean*": "deny",
      "git merge*": "deny",
      "git rebase*": "deny",
      "git checkout main": "deny",
      "git checkout --*": "deny",
      "git switch main": "deny",
      "rm *": "deny",
      "rmdir *": "deny",
      "del *": "deny"
    }
  }
}
