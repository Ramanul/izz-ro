{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python -m generator.main:*)",
      "Bash(python tools/qa_check.py:*)",
      "Bash(python tools/smoke_live.py:*)",
      "Bash(bash tools/audit.sh:*)",
      "Bash(python -m http.server:*)",
      "Bash(pip install -r requirements.txt:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
